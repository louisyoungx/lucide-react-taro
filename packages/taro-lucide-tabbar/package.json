{
  "name": "taro-lucide-tabbar",
  "version": "1.5.0",
  "description": "CLI for generating WeChat miniprogram TabBar PNG icons from Lucide with normal and active states for Taro projects",
  "main": "dist/index.js",
  "bin": {
    "taro-lucide-tabbar": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "lucide-react-taro-generate build-cli --package-dir . --entry src/index.ts --outfile dist/index.js",
    "clean": "rm -rf dist e2e",
    "test": "npm run build && vitest run src/__tests__/cli-e2e.test.ts src/__tests__/utils.test.ts",
    "test:coverage": "npm run build && vitest run --coverage src/__tests__/cli-e2e.test.ts src/__tests__/utils.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lucide",
    "taro",
    "cli",
    "tabbar",
    "icons",
    "png",
    "wechat",
    "miniprogram"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/louisyoungx/lucide-react-taro.git",
    "directory": "packages/taro-lucide-tabbar"
  },
  "homepage": "https://lucide.rocke.top",
  "bugs": {
    "url": "https://github.com/louisyoungx/lucide-react-taro/issues"
  },
  "devDependencies": {
    "@lucide-react-taro/generate": "workspace:*"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "sharp": "^0.33.0"
  }
}
