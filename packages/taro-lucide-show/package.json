{
  "name": "taro-lucide-show",
  "version": "1.4.1",
  "description": "Preview Lucide icons in the terminal",
  "main": "dist/index.js",
  "bin": {
    "taro-lucide-show": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "lucide-react-taro-generate build-cli --package-dir . --entry src/index.ts --outfile dist/index.js",
    "clean": "rm -rf dist src/icon-list.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lucide",
    "taro",
    "cli",
    "preview"
  ],
  "license": "ISC",
  "devDependencies": {
    "@lucide-react-taro/generate": "workspace:*"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "sharp": "^0.33.0"
  }
}
