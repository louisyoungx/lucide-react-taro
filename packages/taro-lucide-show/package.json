{
  "name": "taro-lucide-show",
  "version": "1.5.0",
  "description": "CLI for previewing Lucide icons directly in the terminal with custom size and color before using them in Taro projects",
  "main": "dist/index.js",
  "bin": {
    "taro-lucide-show": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "lucide-react-taro-generate build-cli --package-dir . --entry src/index.ts --outfile dist/index.js",
    "clean": "rm -rf dist src/icon-list.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lucide",
    "taro",
    "cli",
    "preview",
    "icons",
    "terminal",
    "wechat",
    "miniprogram"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/louisyoungx/lucide-react-taro.git",
    "directory": "packages/taro-lucide-show"
  },
  "homepage": "https://lucide.rocke.top",
  "bugs": {
    "url": "https://github.com/louisyoungx/lucide-react-taro/issues"
  },
  "devDependencies": {
    "@lucide-react-taro/generate": "workspace:*"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "sharp": "^0.33.0"
  }
}
